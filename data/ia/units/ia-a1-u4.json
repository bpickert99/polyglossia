{
  "id": "ia-a1-u4",
  "title": "Le familia",
  "level": "A1",
  "summary": "Family words, plus articles and plurals.",
  "lessons": [
    {
      "id": "l1",
      "title": "Matre e patre",
      "teach": [
        {
          "target": "le matre",
          "roman": "le matre",
          "english": "the mother",
          "ipa": "le mˈatre",
          "audio": "audio/le-matre.wav"
        },
        {
          "target": "le patre",
          "roman": "le patre",
          "english": "the father",
          "ipa": "le pˈatre",
          "audio": "audio/le-patre.wav"
        },
        {
          "target": "le fratre",
          "roman": "le fratre",
          "english": "the brother",
          "ipa": "le frˈatre",
          "audio": "audio/le-fratre.wav"
        },
        {
          "target": "le soror",
          "roman": "le soror",
          "english": "the sister",
          "ipa": "le sorˈor",
          "audio": "audio/le-soror.wav"
        },
        {
          "target": "un infante",
          "roman": "un infante",
          "english": "a child",
          "ipa": "un infˈante",
          "audio": "audio/un-infante.wav"
        }
      ],
      "grammar": {
        "title": "Two articles, one plural rule",
        "body": "**le** = the, **un** = a/an — invariable, for every noun.\nPlural: add **-s** (after a vowel) or **-es** (after a consonant):\n| le matre | le matres | the mothers |\n| le soror | le sorores | the sisters |\nNo gender agreement, no der/die/das, no el/la. That's the entire article-and-plural system."
      },
      "exercises": [
        {
          "type": "mc",
          "prompt": "\"Le soror\" means…",
          "choices": [
            "the sister",
            "the brother",
            "the mother",
            "a child"
          ],
          "answer": 0,
          "tts": "le soror"
        },
        {
          "type": "type",
          "prompt": "Make it plural: \"le matre\" →",
          "answer": "le matres",
          "tts": "le matres"
        },
        {
          "type": "listen",
          "ttsText": "le fratre",
          "prompt": "Which did you hear?",
          "choices": [
            "le fratre",
            "le patre",
            "le matre"
          ],
          "answer": 0
        },
        {
          "type": "mc",
          "prompt": "What is the plural of \"le soror\"?",
          "choices": [
            "le sorores",
            "le sorors",
            "les soror",
            "le sorora"
          ],
          "answer": 0
        },
        {
          "type": "match",
          "prompt": "Match the family",
          "pairs": [
            [
              "le matre",
              "the mother"
            ],
            [
              "le patre",
              "the father"
            ],
            [
              "le fratre",
              "the brother"
            ],
            [
              "le soror",
              "the sister"
            ]
          ]
        }
      ]
    },
