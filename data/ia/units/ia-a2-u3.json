{
  "id": "ia-a2-u3",
  "title": "Passato e futuro",
  "level": "A2",
  "summary": "Past with -va, future with -ra. Two endings, all of time.",
  "lessons": [
    {
      "id": "l1",
      "title": "Le passato: -va",
      "teach": [
        {
          "target": "parlava",
          "roman": "parlava",
          "english": "spoke / was speaking",
          "note": "parlar → parlava, for all persons.",
          "ipa": "parlˈava",
          "audio": "audio/parlava.wav"
        },
        {
          "target": "esseva",
          "roman": "esseva",
          "english": "was / were",
          "note": "from esser.",
          "ipa": "esˈeva",
          "audio": "audio/esseva.wav"
        },
        {
          "target": "habeva",
          "roman": "habeva",
          "english": "had",
          "ipa": "habˈeva",
          "audio": "audio/habeva.wav"
        },
        {
          "target": "Heri io mangiava un pomo.",
          "roman": "heri io mangiava un pomo",
          "english": "Yesterday I ate an apple.",
          "note": "heri = yesterday.",
          "ipa": "hˈeriʲ ˈiʲo maŋɡjˈava un pˈomo",
          "audio": "audio/heri-io-mangiava-un-pomo.wav"
        },
        {
          "target": "Illa esseva felice.",
          "roman": "illa esseva felice",
          "english": "She was happy.",
          "ipa": "ˈila esˌeva felˈitse",
          "audio": "audio/illa-esseva-felice.wav"
        }
      ],
      "grammar": {
        "title": "Past tense: add -va",
        "body": "Drop the -r of the infinitive and add **-va**:\n| parlar | parlava | spoke |\n| vider | videva | saw |\n| audir | audiva | heard |\nSame form for every person: io parlava, nos parlava, illes parlava."
      },
      "exercises": [
        {
          "type": "mc",
          "prompt": "\"Esseva\" means…",
          "choices": [
            "was/were",
            "is",
            "will be",
            "has"
          ],
          "answer": 0,
          "tts": "esseva"
        },
        {
          "type": "type",
          "prompt": "Past tense of \"vider\" (to see):",
          "answer": "videva",
          "tts": "videva"
        },
        {
          "type": "listen",
          "ttsText": "heri io mangiava un pomo",
          "prompt": "What did you hear?",
          "choices": [
            "Heri io mangiava un pomo.",
            "Io mangia un pomo.",
            "Illa esseva felice."
          ],
          "answer": 0
        },
        {
          "type": "mc",
          "prompt": "Fill the blank: \"Nos ___ un can.\" (We had a dog)",
          "choices": [
            "habeva",
            "ha",
            "habera",
            "haber"
          ],
          "answer": 0
        },
        {
          "type": "match",
          "prompt": "Match present to past",
          "pairs": [
            [
              "parla",
              "parlava"
            ],
            [
              "es",
              "esseva"
            ],
            [
              "ha",
              "habeva"
            ],
            [
              "vide",
              "videva"
            ]
          ]
        }
      ]
    },
    {
      "id": "l2",
      "title": "Le futuro: -ra",
      "teach": [
        {
          "target": "parlara",
          "roman": "parlara",
          "english": "will speak",
          "note": "Stress the final a: parla-RA.",
          "ipa": "parlˈara",
          "audio": "audio/parlara.wav"
        },
        {
          "target": "essera",
          "roman": "essera",
          "english": "will be",
          "ipa": "esˈera",
          "audio": "audio/essera.wav"
        },
        {
          "target": "deman",
          "roman": "deman",
          "english": "tomorrow",
          "ipa": "demˈan",
          "audio": "audio/deman.wav"
        },
        {
          "target": "Deman io parlara con te.",
          "roman": "deman io parlara con te",
          "english": "Tomorrow I will speak with you.",
          "note": "con te = with you.",
          "ipa": "demˈan ˈiʲo parlˈara kˈon tˈe",
          "audio": "audio/deman-io-parlara-con-te.wav"
        },
        {
          "target": "Tote essera ben.",
          "roman": "tote essera ben",
          "english": "Everything will be fine.",
          "ipa": "tˈote esˈera bˈen",
          "audio": "audio/tote-essera-ben.wav"
        }
      ],
      "exercises": [
        {
          "type": "mc",
          "prompt": "\"Essera\" means…",
          "choices": [
            "will be",
            "was",
            "is",
            "would be"
          ],
          "answer": 0,
          "tts": "essera"
        },
        {
          "type": "type",
          "prompt": "Future of \"mangiar\" (to eat):",
          "answer": "mangiara",
          "tts": "mangiara"
        },
        {
          "type": "listen",
          "ttsText": "deman io parlara con te",
          "prompt": "What did you hear?",
          "choices": [
            "Deman io parlara con te.",
            "Heri io parlava.",
            "Tote essera ben."
          ],
          "answer": 0
        },
        {
          "type": "mc",
          "prompt": "\"Deman\" means…",
          "choices": [
            "tomorrow",
            "yesterday",
            "today",
            "always"
          ],
          "answer": 0,
          "tts": "deman"
        },
        {
          "type": "match",
          "prompt": "Match the tenses of parlar",
          "pairs": [
            [
              "parla",
              "speaks (now)"
            ],
            [
              "parlava",
              "spoke (past)"
            ],
            [
              "parlara",
              "will speak (future)"
            ]
          ]
        }
      ]
    }
  ]
}
