{
  "id": "ia-a1-u2",
  "title": "To Be & Pronouns",
  "level": "A1",
  "summary": "The whole verb system's best surprise: nothing conjugates.",
  "lessons": [
    {
      "id": "l1",
      "title": "Io es, tu es",
      "teach": [
        {
          "target": "io",
          "roman": "io",
          "english": "I",
          "ipa": "ˈiʲo",
          "audio": "audio/io.wav"
        },
        {
          "target": "tu",
          "roman": "tu",
          "english": "you",
          "ipa": "tˈu",
          "audio": "audio/tu.wav"
        },
        {
          "target": "ille / illa",
          "roman": "ille illa",
          "english": "he / she",
          "ipa": "ˈile ˈila",
          "audio": "audio/ille-illa.wav"
        },
        {
          "target": "es",
          "roman": "es",
          "english": "am / is / are",
          "note": "One form for every person. Io es, tu es, illa es — that's it.",
          "ipa": "ˈes",
          "audio": "audio/es.wav"
        },
        {
          "target": "Io es felice.",
          "roman": "io es felice",
          "english": "I am happy.",
          "ipa": "ˈiʲo es felˈitse",
          "audio": "audio/io-es-felice.wav"
        }
      ],
      "grammar": {
        "title": "No conjugation. Ever.",
        "body": "In Interlingua a verb has **one present form for all persons**:\n| io es | I am |\n| tu es | you are |\n| ille/illa es | he/she is |\n| nos es | we are |\nCompare Spanish (soy/eres/es/somos/sois/son) — Interlingua deleted the whole table. What you save in memorization you can spend on vocabulary."
      }
    },
    {
      "id": "l2",
      "title": "We, you all, they — and to have",
      "teach": [
        {
          "target": "nos",
          "roman": "nos",
          "english": "we",
          "ipa": "nˈos",
          "audio": "audio/nos.wav"
        },
        {
          "target": "vos",
          "roman": "vos",
          "english": "you (plural/formal)",
          "ipa": "vˈos",
          "audio": "audio/vos.wav"
        },
        {
          "target": "illes",
          "roman": "illes",
          "english": "they",
          "ipa": "ˈiles",
          "audio": "audio/illes.wav"
        },
        {
          "target": "ha",
          "roman": "ha",
          "english": "has / have",
          "note": "Same trick: io ha, tu ha, nos ha.",
          "ipa": "hˈa",
          "audio": "audio/ha.wav"
        },
        {
          "target": "Nos ha un can.",
          "roman": "nos ha un can",
          "english": "We have a dog.",
          "ipa": "nˈos ha un kˈan",
          "audio": "audio/nos-ha-un-can.wav"
        }
      ]
    }
  ]
}
