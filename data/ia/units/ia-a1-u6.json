      "title": "Matre e patre",
      "teach": [
        {
          "target": "le matre",
          "roman": "le matre",
          "english": "the mother",
          "ipa": "le mˈatre",
          "audio": "audio/le-matre.wav"
        },
        {
          "target": "le patre",
          "roman": "le patre",
          "english": "the father",
          "ipa": "le pˈatre",
          "audio": "audio/le-patre.wav"
        },
        {
          "target": "le fratre",
          "roman": "le fratre",
          "english": "the brother",
          "ipa": "le frˈatre",
          "audio": "audio/le-fratre.wav"
        },
        {
          "target": "le soror",
          "roman": "le soror",
          "english": "the sister",
          "ipa": "le sorˈor",
          "audio": "audio/le-soror.wav"
        },
        {
          "target": "un infante",
          "roman": "un infante",
          "english": "a child",
          "ipa": "un infˈante",
          "audio": "audio/un-infante.wav"
        }
      ],
      "grammar": {
        "title": "Two articles, one plural rule",
        "body": "**le** = the, **un** = a/an — invariable, for every noun.\nPlural: add **-s** (after a vowel) or **-es** (after a consonant):\n| le matre | le matres | the mothers |\n| le soror | le sorores | the sisters |\nNo gender agreement, no der/die/das, no el/la. That's the entire article-and-plural system."
      }
    },
