{
  "id": "ia-a1-u1",
  "title": "Salutes",
  "level": "A1",
  "summary": "Greetings and politeness — you may find you can already read them.",
  "lessons": [
    {
      "id": "l1",
      "title": "Hello and thank you",
      "teach": [
        {
          "target": "salute",
          "roman": "salute",
          "english": "hello",
          "note": "Like 'salute' — a greeting to anyone, any time.",
          "ipa": "salˈute",
          "audio": "audio/salute.wav"
        },
        {
          "target": "bon die",
          "roman": "bon die",
          "english": "good day / good morning",
          "ipa": "bˈon dˈiʲe",
          "audio": "audio/bon-die.wav"
        },
        {
          "target": "gratias",
          "roman": "gratias",
          "english": "thank you",
          "note": "Like Spanish 'gracias' and Latin 'gratias'.",
          "ipa": "ɡrˈatjas",
          "audio": "audio/gratias.wav"
        },
        {
          "target": "per favor",
          "roman": "per favor",
          "english": "please",
          "ipa": "pˈer favˈor",
          "audio": "audio/per-favor.wav"
        },
        {
          "target": "Como sta tu?",
          "roman": "como sta tu",
          "english": "How are you?",
          "ipa": "kˈomo stˈa tˈu",
          "audio": "audio/como-sta-tu.wav"
        }
      ],
      "grammar": {
        "title": "You can already read Interlingua",
        "body": "Interlingua's words are the ones **shared** by English, French, Spanish, Italian, and Portuguese — so as an English speaker you get thousands of words for free.\nPronunciation is simple: every letter is spoken, *c* before e/i sounds like *ts* or *s*, *j* like French *j*, and stress usually falls on the vowel before the last consonant: sa-LU-te, gra-TI-as."
      },
      "exercises": [
        {
          "type": "mc",
          "prompt": "What does \"gratias\" mean?",
          "choices": [
            "thank you",
            "hello",
            "please",
            "goodbye"
          ],
          "answer": 0,
          "tts": "gratias"
        },
        {
          "type": "listen",
          "ttsText": "bon die",
          "prompt": "Which greeting did you hear?",
          "choices": [
            "bon die",
            "salute",
            "per favor"
          ],
          "answer": 0
        },
        {
          "type": "type",
          "prompt": "Translate to Interlingua: \"please\"",
          "answer": "per favor",
          "tts": "per favor"
        },
        {
          "type": "mc",
          "prompt": "\"Como sta tu?\" asks…",
          "choices": [
            "How are you?",
            "What is your name?",
            "Where do you live?",
            "How old are you?"
          ],
          "answer": 0,
          "tts": "como sta tu"
        },
        {
          "type": "match",
          "prompt": "Match Interlingua to English",
          "pairs": [
            [
              "salute",
              "hello"
            ],
            [
              "gratias",
              "thank you"
            ],
            [
              "per favor",
              "please"
            ],
            [
              "bon die",
              "good day"
            ]
          ]
        }
      ]
    },
    {
      "id": "l2",
      "title": "Yes, no, goodbye",
      "teach": [
        {
          "target": "si",
          "roman": "si",
          "english": "yes",
          "ipa": "sˈi",
          "audio": "audio/si.wav"
        },
        {
          "target": "no",
          "roman": "no",
          "english": "no",
          "ipa": "nˈo",
          "audio": "audio/no.wav"
        },
        {
          "target": "bon nocte",
          "roman": "bon nocte",
          "english": "good night",
          "ipa": "bˈon nˈokte",
          "audio": "audio/bon-nocte.wav"
        },
        {
          "target": "a revider",
          "roman": "a revider",
          "english": "goodbye (see you again)",
          "note": "Literally 're-see' — like French 'au revoir'.",
          "ipa": "a rˌevidˈer",
          "audio": "audio/a-revider.wav"
        },
        {
          "target": "Io sta ben, gratias.",
          "roman": "io sta ben gratias",
          "english": "I'm fine, thank you.",
          "ipa": "ˈiʲo stˈa bˈen ɡrˈatjas",
          "audio": "audio/io-sta-ben-gratias.wav"
        }
      ],
      "exercises": [
        {
          "type": "mc",
          "prompt": "Pick the natural reply to \"Como sta tu?\"",
          "choices": [
            "Io sta ben, gratias.",
            "Bon nocte.",
            "A revider.",
            "No."
          ],
          "answer": 0,
          "tts": "io sta ben gratias"
        },
        {
          "type": "listen",
          "ttsText": "a revider",
          "prompt": "Which phrase did you hear?",
          "choices": [
            "a revider",
            "bon nocte",
            "per favor"
          ],
          "answer": 0
        },
        {
          "type": "type",
          "prompt": "Translate to Interlingua: \"good night\"",
          "answer": "bon nocte",
          "tts": "bon nocte"
        },
        {
          "type": "mc",
          "prompt": "\"A revider\" literally means…",
          "choices": [
            "to re-see (see you again)",
            "good luck",
            "sleep well",
            "welcome"
          ],
          "answer": 0
        },
        {
          "type": "match",
          "prompt": "Match the phrases",
          "pairs": [
            [
              "si",
              "yes"
            ],
            [
              "no",
              "no"
            ],
            [
              "bon nocte",
              "good night"
            ],
            [
              "a revider",
              "goodbye"
            ]
          ]
        }
      ]
    }
  ]
}
