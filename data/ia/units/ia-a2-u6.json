        {
          "target": "Hodie il pluve multo.",
          "roman": "hodie il pluve multo",
          "english": "Today it's raining a lot.",
          "note": "pluver = to rain, an impersonal verb like English 'it rains'.",
          "ipa": "hˈodje il plˈuve mˈulto",
          "audio": "audio/hodie-il-pluve-multo.wav"
        }
      ],
      "grammar": {
        "title": "Weather verbs",
        "body": "Weather uses the dummy subject **il**, like English \"it\": **il pluve** (it rains), **il nive** (it snows), **il face frigide** (it's cold — literally 'it makes cold').\nCommon weather adjectives: **calide** (hot), **frigide** (cold), **nubilose** (cloudy)."
      }
    },
