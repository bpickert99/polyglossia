  "level": "A2",
  "summary": "A verb toolkit: speak, see, hear, go, love.",
  "lessons": [
    {
      "id": "l1",
      "title": "Parlar, vider, audir",
      "teach": [
        {
          "target": "parlar",
          "roman": "parlar",
          "english": "to speak",
          "note": "io parla, tu parla…",
          "ipa": "parlˈar",
          "audio": "audio/parlar.wav"
        },
        {
          "target": "vider",
          "roman": "vider",
          "english": "to see",
          "note": "io vide",
          "ipa": "vidˈer",
          "audio": "audio/vider.wav"
        },
        {
          "target": "audir",
          "roman": "audir",
          "english": "to hear",
          "note": "io audi",
          "ipa": "aʊdˈir",
          "audio": "audio/audir.wav"
        },
        {
          "target": "Io parla interlingua!",
          "roman": "io parla interlingua",
          "english": "I speak Interlingua!",
          "ipa": "ˈiʲo pˈarla ˌinterlˈiŋɡwa",
          "audio": "audio/io-parla-interlingua.wav"
        },
        {
          "target": "Tu vide le can?",
          "roman": "tu vide le can",
          "english": "Do you see the dog?",
          "note": "Questions can be just intonation — no word-order gymnastics needed.",
          "ipa": "tˈu vˈide le kˈan",
          "audio": "audio/tu-vide-le-can.wav"
        }
      ]
    },
    {
      "id": "l2",
      "title": "Vader e amar",
      "teach": [
        {
          "target": "vader",
          "roman": "vader",
          "english": "to go",
          "note": "io vade a casa — I go home.",
          "ipa": "vadˈer",
          "audio": "audio/vader.wav"
        },
        {
          "target": "amar",
          "roman": "amar",
          "english": "to love",
          "ipa": "amˈar",
          "audio": "audio/amar.wav"
        },
        {
          "target": "apprender",
          "roman": "apprender",
          "english": "to learn",
          "ipa": "ˌaprendˈer",
          "audio": "audio/apprender.wav"
        },
        {
          "target": "Io ama apprender linguas.",
          "roman": "io ama apprender linguas",
          "english": "I love learning languages.",
          "ipa": "ˈiʲo ˈama ˌaprendˈer lˈiŋɡwas",
          "audio": "audio/io-ama-apprender-linguas.wav"
        },
        {
          "target": "Nos vade al parco.",
          "roman": "nos vade al parco",
          "english": "We go to the park.",
          "note": "a + le = al.",
          "ipa": "nˈos vˈade al pˈarko",
          "audio": "audio/nos-vade-al-parco.wav"
        }
      ],
      "grammar": {
        "title": "Chaining verbs",
        "body": "Use a conjugated verb + an infinitive, exactly like English:\n| Io ama **apprender**. | I love **to learn**. |\n| Io vole **parlar**. | I want **to speak**. |\nAnd two tiny contractions: **a + le = al** (to the), **de + le = del** (of the)."
      }
    }
  ]
}
