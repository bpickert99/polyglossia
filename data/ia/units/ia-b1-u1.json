{
  "id": "ia-b1-u1",
  "title": "Conversation",
  "level": "B1",
  "summary": "Connect your sentences: but, and, or, if — and keep a conversation going.",
  "lessons": [
    {
      "id": "l1",
      "title": "Ma, e, o",
      "teach": [
        {
          "target": "e",
          "roman": "e",
          "english": "and",
          "ipa": "ˈe",
          "audio": "audio/e.wav"
        },
        {
          "target": "ma",
          "roman": "ma",
          "english": "but",
          "ipa": "mˈa",
          "audio": "audio/ma.wav"
        },
        {
          "target": "o",
          "roman": "o",
          "english": "or",
          "ipa": "ˈo",
          "audio": "audio/o.wav"
        },
        {
          "target": "si",
          "roman": "si",
          "english": "if",
          "note": "Same spelling as 'yes' — context makes it clear, like 'si' in Spanish/Italian.",
          "ipa": "sˈi",
          "audio": "audio/si.wav"
        },
        {
          "target": "Io parla interlingua, ma io ancora apprende.",
          "roman": "io parla interlingua ma io ancora apprende",
          "english": "I speak Interlingua, but I'm still learning.",
          "note": "ancora = still/yet.",
          "ipa": "ˈiʲo pˈarla ˌinterlˈiŋɡwa mˈa ˈiʲo ankˈora aprˈende",
          "audio": "audio/io-parla-interlingua-ma-io-ancora-apprende.wav"
        }
      ]
    },
    {
      "id": "l2",
      "title": "Keeping it going",
      "teach": [
        {
          "target": "Io non comprende.",
          "roman": "io non comprende",
          "english": "I don't understand.",
          "note": "non before the verb negates it.",
          "ipa": "ˈiʲo nˈon komprˈende",
          "audio": "audio/io-non-comprende.wav"
        },
        {
          "target": "Pote tu repeter?",
          "roman": "pote tu repeter",
          "english": "Can you repeat?",
          "note": "poter = to be able; pote = can.",
          "ipa": "pˈote tˈu rˌepetˈer",
          "audio": "audio/pote-tu-repeter.wav"
        },
        {
          "target": "Como se dice ... in interlingua?",
          "roman": "como se dice in interlingua",
          "english": "How do you say ... in Interlingua?",
          "ipa": "kˈomo sˈe dˈitse ˈin ˌinterlˈiŋɡwa",
          "audio": "audio/como-se-dice-in-interlingua.wav"
        },
        {
          "target": "Naturalmente!",
          "roman": "naturalmente",
          "english": "Of course!",
          "note": "Adverbs end in -mente, like Romance languages.",
          "ipa": "nˌaturalmˈente",
          "audio": "audio/naturalmente.wav"
        },
        {
          "target": "Multo ben!",
          "roman": "multo ben",
          "english": "Very good!",
          "ipa": "mˈulto bˈen",
          "audio": "audio/multo-ben.wav"
        }
      ],
      "grammar": {
        "title": "Negation and adverbs",
        "body": "Negate any verb with **non** before it: io comprende → io **non** comprende.\nMake adverbs with **-mente** on the adjective: natural → natural**mente** (naturally), felice → felice**mente** (happily).\nWith connectors, questions, three tenses, and negation, you can now improvise real conversations — the rest is vocabulary."
      }
    }
  ],
  "reading": {
    "title": "In le tren",
    "passage": [
      "Anna: Bon die! Como sta tu?",
      "Marco: Io sta ben, gratias! E tu?",
      "Anna: Io es felice hodie.",
      "Marco: Proque?",
      "Anna: Proque deman io vadera al parco con mi amico.",
      "Marco: Multo ben! Ma io non pote vader — io ha labor deman."
    ],
    "questions": [
      {
        "prompt": "How does Marco say he's doing?",
        "choices": [
          "Well",
          "Bad",
          "Tired",
          "Sick"
        ],
        "answer": 0
      },
      {
        "prompt": "Why is Anna happy today?",
        "choices": [
          "She's going to the park with her friend tomorrow",
          "She got a new job",
          "It's her birthday",
          "She's on vacation"
        ],
        "answer": 0
      },
      {
        "prompt": "Why can't Marco go?",
        "choices": [
          "He has work tomorrow",
          "He's sick",
          "He doesn't like parks",
          "He's busy today"
        ],
        "answer": 0
      },
      {
        "prompt": "What does \"Multo ben!\" mean?",
        "choices": [
          "Very good!",
          "Very bad",
          "See you later",
          "I'm sorry"
        ],
        "answer": 0
      }
    ]
  }
}
