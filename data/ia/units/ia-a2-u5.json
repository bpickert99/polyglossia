          "target": "le septimana",
          "roman": "le septimana",
          "english": "the week",
          "ipa": "le sˌeptimˈana",
          "audio": "audio/le-septimana.wav"
        },
        {
          "target": "Le lection es lunedi.",
          "roman": "le lection es lunedi",
          "english": "The lesson is on Monday.",
          "note": "lection = lesson.",
          "ipa": "le lektjˈon es lˌunedˈi",
          "audio": "audio/le-lection-es-lunedi.wav"
        }
      ],
      "grammar": {
        "title": "Days of the week",
        "body": "All seven days end in **-di** (from *die*, day): lunedi, martedi, mercuridi, jovedi, venerdi, sabbato, dominica.\nNo preposition is needed for \"on\" a day — **le lection es lunedi** already means \"the lesson is on Monday.\""
      }
    },
