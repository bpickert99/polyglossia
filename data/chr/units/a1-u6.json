      "id": "l1",
      "title": "First colors",
      "teach": [
        { "target": "ᎩᎦᎨ", "roman": "gigage", "english": "red", "note": "From ᎩᎦ (giga, blood) + -ge." },
        { "target": "ᎤᏁᎦ", "roman": "unega", "english": "white" },
        { "target": "ᎬᎾᎨ", "roman": "gvnage", "english": "black" },
        { "target": "ᏓᎶᏂᎨ", "roman": "dalonige", "english": "yellow" }
      ],
      "grammar": {
        "title": "The -ge 'colored like' ending",
        "body": "Many Cherokee color words end in **-ge**, meaning roughly 'colored like'.\n| ᎩᎦ giga | blood | → ᎩᎦᎨ gigage | red |\n| ᏓᎶᏂ daloni | bile/yellowish | → ᏓᎶᏂᎨ dalonige | yellow |\nSpotting -ge at the end of a word is a good clue you're looking at a color."
      },
      "exercises": [
        { "type": "mc", "prompt": "What does ᎩᎦᎨ (gigage) mean?", "choices": ["red", "white", "black", "yellow"], "answer": 0, "tts": "gigage" },
        { "type": "listen", "ttsText": "unega", "prompt": "Which color did you hear?", "choices": ["ᎤᏁᎦ (white)", "ᎬᎾᎨ (black)", "ᏓᎶᏂᎨ (yellow)"], "answer": 0 },
        { "type": "mc", "prompt": "The ending -ge on a Cherokee word often signals…", "choices": ["a color", "a question", "a plural", "past tense"], "answer": 0 },
        { "type": "type", "prompt": "Type the romanization of ᎬᎾᎨ (black)", "answer": "gvnage", "tts": "gvnage" },
        { "type": "match", "prompt": "Match the colors", "pairs": [["ᎩᎦᎨ", "red"], ["ᎤᏁᎦ", "white"], ["ᎬᎾᎨ", "black"], ["ᏓᎶᏂᎨ", "yellow"]] }
      ]
    },
    {
      "id": "l2",
      "title": "More colors & the four directions",
      "teach": [
        { "target": "ᏌᎪᏂᎨ", "roman": "sakonige", "english": "blue" },
        { "target": "ᎢᏤᏳᏍᏗ", "roman": "itseyusdi", "english": "green", "note": "Related to ᎢᏤ (itse), 'new / fresh' — the color of new growth." },
        { "target": "ᎤᏬᏗᎨ", "roman": "uwodige", "english": "brown" },
        { "target": "ᎩᎦᎨ ᏥᏍᏆ", "roman": "gigage tsisqua", "english": "a red bird", "note": "Color words can follow the noun they describe. A cardinal!" }
      ],
      "culture": {
        "title": "Colors of the four directions",
        "body": "In Cherokee tradition each cardinal direction carries a color and a meaning: **east is red** (success, victory), **north is blue** (trouble, defeat), **west is black** (death), and **south is white** (peace, happiness). These pairings appear across stories, ceremonies, and older formulas — so color words carry more than paint-chip meanings."
      },
      "exercises": [
        { "type": "mc", "prompt": "What does ᏌᎪᏂᎨ (sakonige) mean?", "choices": ["blue", "green", "brown", "red"], "answer": 0, "tts": "sakonige" },
        { "type": "listen", "ttsText": "itseyusdi", "prompt": "Which color did you hear?", "choices": ["ᎢᏤᏳᏍᏗ (green)", "ᏌᎪᏂᎨ (blue)", "ᎤᏬᏗᎨ (brown)"], "answer": 0 },
        { "type": "mc", "prompt": "In the four-directions tradition, white (south) is associated with…", "choices": ["peace and happiness", "trouble", "death", "war"], "answer": 0 },
        { "type": "mc", "prompt": "ᎩᎦᎨ ᏥᏍᏆ (gigage tsisqua) means…", "choices": ["a red bird", "a black bear", "a blue fish", "a yellow flower"], "answer": 0, "tts": "gigage tsisqua" },
        { "type": "match", "prompt": "Match the colors", "pairs": [["ᏌᎪᏂᎨ", "blue"], ["ᎢᏤᏳᏍᏗ", "green"], ["ᎤᏬᏗᎨ", "brown"], ["ᎤᏁᎦ", "white"]] }
      ]
    }
  ]
