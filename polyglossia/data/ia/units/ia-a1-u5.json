      "exercises": [
        { "type": "mc", "prompt": "\"Le lacte\" means…", "choices": ["the milk", "the water", "the bread", "the coffee"], "answer": 0, "tts": "le lacte" },
        { "type": "listen", "ttsText": "le pan", "prompt": "Which did you hear?", "choices": ["le pan", "le caffe", "le aqua"], "answer": 0 },
        { "type": "type", "prompt": "Translate: \"I want water, please.\"", "answer": "io vole aqua per favor", "accept": ["io vole aqua, per favor"], "tts": "io vole aqua per favor" },
        { "type": "mc", "prompt": "Fill the blank: \"Tu ___ caffe?\" (Do you want coffee?)", "choices": ["vole", "es", "ha", "sta"], "answer": 0 },
