    {
      "id": "l2",
      "title": "Mangiar",
      "teach": [
        { "target": "mangiar", "roman": "mangiar", "english": "to eat" },
        { "target": "biber", "roman": "biber", "english": "to drink" },
        { "target": "le pomo", "roman": "le pomo", "english": "the apple" },
        { "target": "le caseo", "roman": "le caseo", "english": "the cheese" },
        { "target": "Io mangia un pomo.", "roman": "io mangia un pomo", "english": "I am eating an apple.", "note": "Present tense = infinitive minus -r: mangiar → mangia." }
      ],
      "grammar": {
        "title": "Every verb, one rule",
        "body": "Take the infinitive, drop the final **-r**, and you have the present tense for all persons:\n| mangiar (to eat) | io mangia, tu mangia, nos mangia |\n| biber (to drink) | io bibe, illa bibe |\n| voler (to want) | io vole |\nYou now know how to conjugate every verb in the language."
      },
      "exercises": [
        { "type": "mc", "prompt": "\"Illa bibe lacte\" means…", "choices": ["She drinks milk", "She eats bread", "He wants milk", "She has milk"], "answer": 0, "tts": "illa bibe lacte" },
        { "type": "type", "prompt": "Present of \"biber\" (to drink): io ___", "answer": "bibe", "tts": "bibe" },
        { "type": "listen", "ttsText": "le pomo", "prompt": "Which did you hear?", "choices": ["le pomo", "le caseo", "le pan"], "answer": 0 },
        { "type": "mc", "prompt": "Fill the blank: \"Nos ___ caseo.\" (We eat cheese)", "choices": ["mangia", "mangiar", "bibe", "vole"], "answer": 0 },
        { "type": "match", "prompt": "Match the words", "pairs": [["mangiar", "to eat"], ["biber", "to drink"], ["le pomo", "the apple"], ["le caseo", "the cheese"]] }
      ]
    }
  ]
