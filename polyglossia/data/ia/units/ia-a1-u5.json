        { "target": "le lacte", "roman": "le lacte", "english": "the milk" },
        { "target": "le caffe", "roman": "le caffe", "english": "the coffee" },
        { "target": "Io vole aqua, per favor.", "roman": "io vole aqua per favor", "english": "I want water, please.", "note": "vole = want(s) — invariable like every verb." }
