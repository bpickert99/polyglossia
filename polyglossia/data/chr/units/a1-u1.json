{
  "id": "a1-u1",
  "title": "The Syllabary I",
  "level": "A1",
  "summary": "Meet Sequoyah's writing system: the six vowels and your first readable words.",
  "lessons": [
    {
      "id": "l1",
      "title": "The six vowels",
      "teach": [
        { "target": "Ꭰ", "roman": "a", "english": "the vowel 'a'", "note": "Sounds like the a in 'father'." },
        { "target": "Ꭱ", "roman": "e", "english": "the vowel 'e'", "note": "Sounds like the a in 'cake'." },
        { "target": "Ꭲ", "roman": "i", "english": "the vowel 'i'", "note": "Sounds like the ee in 'see'." },
        { "target": "Ꭳ", "roman": "o", "english": "the vowel 'o'", "note": "Sounds like the o in 'go'." },
        { "target": "Ꭴ", "roman": "u", "english": "the vowel 'u'", "note": "Sounds like the oo in 'moon'." },
        { "target": "Ꭵ", "roman": "v", "english": "the nasal vowel 'v'", "note": "A nasalized 'uh', like the u in 'uh-huh'. Written 'v' in romanization." }
      ],
      "grammar": {
        "title": "A syllabary, not an alphabet",
        "body": "Cherokee is written with a **syllabary**: each character is a whole syllable, not a single letter.\n**ᎣᏏᏲ** (hello) is three characters — o + si + yo — not five letters.\nThere are 85 characters. That sounds like a lot, but they follow a grid: rows share a consonant, columns share a vowel. Once you know the six vowels, every other character is 'consonant + one of these vowels'.\nVisit the ✍️ Script tab any time to practice drawing them."
      },
      "exercises": [
        { "type": "mc", "prompt": "Which character is the vowel 'a'?", "choices": ["Ꭰ", "Ꭱ", "Ꭲ", "Ꭵ"], "answer": 0, "tts": "a" },
        { "type": "mc", "prompt": "What sound does Ꭴ make?", "choices": ["u (as in moon)", "e (as in cake)", "a (as in father)", "v (nasal uh)"], "answer": 0, "tts": "u" },
        { "type": "listen", "ttsText": "e", "prompt": "Which vowel did you hear?", "choices": ["Ꭱ", "Ꭲ", "Ꭳ", "Ꭰ"], "answer": 0 },
        { "type": "match", "prompt": "Match each character to its sound", "pairs": [["Ꭰ", "a"], ["Ꭲ", "i"], ["Ꭳ", "o"], ["Ꭵ", "v"]] },
        { "type": "mc", "prompt": "The character Ꭵ stands for…", "choices": ["a nasal 'uh' sound", "the letter v as in 'very'", "the vowel o", "silence"], "answer": 0 }
      ]
    },
    {
      "id": "l2",
      "title": "Your first words",
      "teach": [
        { "target": "ᎣᏏᏲ", "roman": "osiyo", "english": "hello", "note": "Ꭳ (o) + Ꮟ (si) + Ᏺ (yo). The most useful word in the course!" },
        { "target": "ᏩᏙ", "roman": "wado", "english": "thank you", "note": "Ꮹ (wa) + Ꮩ (do)." },
        { "target": "ᎠᎹ", "roman": "ama", "english": "water", "note": "Ꭰ (a) + Ꮉ (ma)." },
        { "target": "ᎠᎹ ᏩᏙ", "roman": "ama wado", "english": "water, thank you", "note": "Two words you already know, working together." }
      ],
      "exercises": [
        { "type": "mc", "prompt": "How many characters spell ᎣᏏᏲ (osiyo)?", "choices": ["3", "5", "2", "6"], "answer": 0 },
        { "type": "mc", "prompt": "What does ᏩᏙ mean?", "choices": ["thank you", "hello", "water", "goodbye"], "answer": 0, "tts": "wado" },
        { "type": "type", "prompt": "Type the romanization of ᎠᎹ (water)", "answer": "ama", "accept": ["a ma"], "tts": "ama" },
        { "type": "listen", "ttsText": "osiyo", "prompt": "Which word did you hear?", "choices": ["ᎣᏏᏲ", "ᏩᏙ", "ᎠᎹ"], "answer": 0 },
        { "type": "match", "prompt": "Match Cherokee to English", "pairs": [["ᎣᏏᏲ", "hello"], ["ᏩᏙ", "thank you"], ["ᎠᎹ", "water"]] }
      ]
    }
  ]
}
