      "culture": {
        "title": "Selu, the Corn Mother",
        "body": "**ᏎᎷ** (Selu) is more than the word for corn — in Cherokee tradition Selu is the Corn Mother, the first woman, whose story explains where corn came from and why it must be treated with respect. Her husband **Kanati** is the Lucky Hunter. Corn, beans, and squash — grown together — anchored traditional Cherokee agriculture."
      },
      "exercises": [
        { "type": "mc", "prompt": "What does ᏎᎷ (selu) mean?", "choices": ["corn", "bread", "milk", "coffee"], "answer": 0, "tts": "selu" },
        { "type": "listen", "ttsText": "agiyosiha", "prompt": "Which phrase did you hear?", "choices": ["ᎠᎩᏲᏏᎭ (I am hungry)", "ᎦᏚ (bread)", "ᎧᏫ (coffee)"], "answer": 0 },
        { "type": "type", "prompt": "Type the romanization of ᎦᏚ (bread)", "answer": "gadu", "tts": "gadu" },
        { "type": "mc", "prompt": "In Cherokee tradition, Selu is…", "choices": ["the Corn Mother", "the god of rain", "a warrior chief", "the word for kitchen"], "answer": 0 },
        { "type": "match", "prompt": "Match the food words", "pairs": [["ᎦᏚ", "bread"], ["ᏎᎷ", "corn"], ["ᎧᏫ", "coffee"], ["ᎤᏅᏗ", "milk"]] }
      ]
