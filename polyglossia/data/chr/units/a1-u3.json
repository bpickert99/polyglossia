{
  "id": "a1-u3",
  "title": "Numbers 1–10",
  "level": "A1",
  "summary": "Count to ten in Cherokee.",
  "lessons": [
    {
      "id": "l1",
      "title": "One to five",
      "teach": [
        { "target": "ᏌᏊ", "roman": "saquu", "english": "one" },
        { "target": "ᏔᎵ", "roman": "tali", "english": "two" },
        { "target": "ᏦᎢ", "roman": "tsoi", "english": "three" },
        { "target": "ᏅᎩ", "roman": "nvgi", "english": "four" },
        { "target": "ᎯᏍᎩ", "roman": "hisgi", "english": "five" }
      ],
      "exercises": [
        { "type": "mc", "prompt": "What is ᏔᎵ (tali)?", "choices": ["two", "one", "four", "five"], "answer": 0, "tts": "tali" },
        { "type": "listen", "ttsText": "nvgi", "prompt": "Which number did you hear?", "choices": ["ᏅᎩ (four)", "ᏦᎢ (three)", "ᎯᏍᎩ (five)"], "answer": 0 },
        { "type": "mc", "prompt": "Which is the word for 'five'?", "choices": ["ᎯᏍᎩ", "ᏌᏊ", "ᏔᎵ", "ᏅᎩ"], "answer": 0, "tts": "hisgi" },
        { "type": "type", "prompt": "Type the romanization of ᏦᎢ (three)", "answer": "tsoi", "accept": ["tso i"], "tts": "tsoi" },
        { "type": "match", "prompt": "Match number words", "pairs": [["ᏌᏊ", "1"], ["ᏔᎵ", "2"], ["ᏦᎢ", "3"], ["ᏅᎩ", "4"], ["ᎯᏍᎩ", "5"]] }
      ]
    },
    {
      "id": "l2",
      "title": "Six to ten",
      "teach": [
        { "target": "ᏑᏓᎵ", "roman": "sudali", "english": "six" },
        { "target": "ᎦᎵᏉᎩ", "roman": "galiquogi", "english": "seven", "note": "Seven is a sacred number in Cherokee tradition — seven clans, seven directions." },
        { "target": "ᏧᏁᎳ", "roman": "tsunela", "english": "eight" },
        { "target": "ᏐᏁᎳ", "roman": "sonela", "english": "nine" },
        { "target": "ᏍᎪᎯ", "roman": "sgohi", "english": "ten" }
      ],
      "culture": {
        "title": "The number seven",
        "body": "Seven — **ᎦᎵᏉᎩ** (galiquogi) — appears throughout Cherokee tradition: there are **seven clans** (Wolf, Deer, Bird, Paint, Long Hair, Blue, and Wild Potato), and ceremonies recognize seven directions: the four cardinal directions plus up, down, and center."
      },
      "exercises": [
        { "type": "mc", "prompt": "What is ᏍᎪᎯ (sgohi)?", "choices": ["ten", "six", "eight", "seven"], "answer": 0, "tts": "sgohi" },
        { "type": "listen", "ttsText": "galiquogi", "prompt": "Which number did you hear?", "choices": ["ᎦᎵᏉᎩ (seven)", "ᏑᏓᎵ (six)", "ᏐᏁᎳ (nine)"], "answer": 0 },
        { "type": "mc", "prompt": "How many clans are in the Cherokee tradition?", "choices": ["ᎦᎵᏉᎩ (seven)", "ᏅᎩ (four)", "ᏍᎪᎯ (ten)", "ᏦᎢ (three)"], "answer": 0 },
        { "type": "type", "prompt": "Type the romanization of ᏑᏓᎵ (six)", "answer": "sudali", "tts": "sudali" },
        { "type": "match", "prompt": "Match number words", "pairs": [["ᏑᏓᎵ", "6"], ["ᎦᎵᏉᎩ", "7"], ["ᏧᏁᎳ", "8"], ["ᏐᏁᎳ", "9"], ["ᏍᎪᎯ", "10"]] }
      ]
    }
  ]
}
