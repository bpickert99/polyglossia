      ],
      "exercises": [
        { "type": "mc", "prompt": "What does ᎠᎦᏍᎦ (agasga) mean?", "choices": ["it is raining", "it is cold", "it is warm", "the sun"], "answer": 0, "tts": "agasga" },
        { "type": "listen", "ttsText": "uyvtla", "prompt": "Which phrase did you hear?", "choices": ["ᎤᏴᏝ (it is cold)", "ᎤᎦᎾᏩ (it is warm)", "ᎠᎦᏍᎦ (it is raining)"], "answer": 0 },
