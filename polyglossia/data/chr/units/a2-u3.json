      "id": "l2",
      "title": "Seasons & the land",
      "teach": [
        { "target": "ᎪᎩ", "roman": "gogi", "english": "summer" },
        { "target": "ᎪᎳ", "roman": "gola", "english": "winter" },
        { "target": "ᎢᎦ", "roman": "iga", "english": "day" },
        { "target": "ᏒᏃᏱ", "roman": "svnoyi", "english": "night" },
        { "target": "ᎣᏓᎸ", "roman": "odalv", "english": "mountain", "note": "The homeland of the Cherokee is the southern Appalachians." }
      ],
      "culture": {
        "title": "The mountains are home",
        "body": "The Cherokee homeland spans the **southern Appalachian mountains** — today's western North Carolina, eastern Tennessee, and north Georgia. After the forced removal of 1838–39 (the **Trail of Tears**, ᏅᎾ ᏓᎤᎳ ᏨᏱ 'the trail where they cried'), most Cherokee people rebuilt in Oklahoma, while the Eastern Band remained in the mountains. Place, season, and language remain deeply connected: many Cherokee place names survive across the region — 'Tennessee' itself comes from the Cherokee town name ᏔᎾᏏ (Tanasi)."
      },
      "exercises": [
        { "type": "mc", "prompt": "What does ᎪᎳ (gola) mean?", "choices": ["winter", "summer", "day", "night"], "answer": 0, "tts": "gola" },
        { "type": "listen", "ttsText": "svnoyi", "prompt": "Which word did you hear?", "choices": ["ᏒᏃᏱ (night)", "ᎢᎦ (day)", "ᎪᎩ (summer)"], "answer": 0 },
        { "type": "mc", "prompt": "The name 'Tennessee' comes from…", "choices": ["the Cherokee town name Tanasi", "an English explorer", "a French fort", "a Spanish mission"], "answer": 0 },
        { "type": "type", "prompt": "Type the romanization of ᎣᏓᎸ (mountain)", "answer": "odalv", "tts": "odalv" },
        { "type": "match", "prompt": "Match the words", "pairs": [["ᎪᎩ", "summer"], ["ᎪᎳ", "winter"], ["ᎢᎦ", "day"], ["ᏒᏃᏱ", "night"]] }
      ]
    }
  ]
