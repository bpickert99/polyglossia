{
  "id": "a1-u2",
  "title": "Greetings",
  "level": "A1",
  "summary": "Say hello, ask how someone is, and answer politely.",
  "lessons": [
    {
      "id": "l1",
      "title": "Hello, how are you?",
      "teach": [
        { "target": "ᎣᏏᏲ", "roman": "osiyo", "english": "hello", "note": "Used any time of day." },
        { "target": "ᏙᎯᏧ", "roman": "tohitsu", "english": "how are you?", "note": "A common everyday greeting question." },
        { "target": "ᎣᏍᏓ", "roman": "osda", "english": "good / fine", "note": "The natural answer to tohitsu." },
        { "target": "ᏙᎯᏊ", "roman": "tohiquu", "english": "I'm fine (at peace)", "note": "Literally 'peaceful' — a warm way to answer." },
        { "target": "ᏂᎯᎾ", "roman": "nihina", "english": "and you?", "note": "Bounce the question back." }
      ],
      "culture": {
        "title": "Greeting with peace",
        "body": "Cherokee greetings center on the idea of **tohi** — peace, wellness, balance. Asking ᏙᎯᏧ (tohitsu) is literally asking whether someone is in a state of peace, and answering ᏙᎯᏊ says that you are. Wellness and harmony, not just politeness, are built into the exchange."
      },
      "exercises": [
        { "type": "mc", "prompt": "Someone says ᏙᎯᏧ (tohitsu). What are they asking?", "choices": ["How are you?", "What is your name?", "Where are you going?", "Are you hungry?"], "answer": 0, "tts": "tohitsu" },
        { "type": "mc", "prompt": "Pick the best reply to ᏙᎯᏧ:", "choices": ["ᎣᏍᏓ (osda)", "ᎠᎹ (ama)", "ᏩᏙ (wado)", "ᎣᏏᏲ (osiyo)"], "answer": 0 },
        { "type": "listen", "ttsText": "osda", "prompt": "Which word did you hear?", "choices": ["ᎣᏍᏓ", "ᎣᏏᏲ", "ᏙᎯᏧ"], "answer": 0 },
        { "type": "type", "prompt": "Type the romanization for 'hello'", "answer": "osiyo", "accept": ["o siyo", "osiyoh"], "tts": "osiyo" },
        { "type": "match", "prompt": "Match the conversation", "pairs": [["ᎣᏏᏲ", "hello"], ["ᏙᎯᏧ", "how are you?"], ["ᎣᏍᏓ", "good"], ["ᏂᎯᎾ", "and you?"]] }
      ]
    },
    {
      "id": "l2",
      "title": "Yes, no, goodbye",
      "teach": [
        { "target": "ᎥᎥ", "roman": "vv", "english": "yes", "note": "Two nasal vowels — sounds like 'uh-huh'." },
        { "target": "Ꮭ", "roman": "tla", "english": "no", "note": "A single character. Also used as 'not'." },
        { "target": "ᎰᏩ", "roman": "howa", "english": "okay / alright", "note": "Agreeing to something." },
        { "target": "ᏙᎾᏓᎪᎲᎢ", "roman": "donadagohvi", "english": "goodbye (until we meet again)", "note": "Cherokee has no word for a final 'goodbye' — this means 'we will see each other again'." }
      ],
      "grammar": {
        "title": "There is no 'goodbye'",
        "body": "Cherokee farewells assume you'll meet again. **ᏙᎾᏓᎪᎲᎢ** (donadagohvi) is said to one person or a group you'll see later — literally 'until we see each other again'.\nSimilarly, ᎥᎥ (vv, 'yes') is those two nasal Ꭵ vowels in a row — say 'uh-huh' through your nose and you're very close."
      },
      "exercises": [
        { "type": "mc", "prompt": "What does Ꮭ (tla) mean?", "choices": ["no / not", "yes", "okay", "hello"], "answer": 0, "tts": "tla" },
        { "type": "listen", "ttsText": "donadagohvi", "prompt": "Which phrase did you hear?", "choices": ["ᏙᎾᏓᎪᎲᎢ", "ᏙᎯᏧ", "ᎣᏏᏲ"], "answer": 0 },
        { "type": "mc", "prompt": "ᏙᎾᏓᎪᎲᎢ (donadagohvi) literally means…", "choices": ["until we see each other again", "good night forever", "walk quickly", "thank you very much"], "answer": 0 },
        { "type": "type", "prompt": "Type the romanization for 'yes'", "answer": "vv", "accept": ["v v", "uhuh"], "tts": "vv" },
        { "type": "match", "prompt": "Match Cherokee to English", "pairs": [["ᎥᎥ", "yes"], ["Ꮭ", "no"], ["ᎰᏩ", "okay"], ["ᏙᎾᏓᎪᎲᎢ", "goodbye"]] }
      ]
    }
  ]
}
